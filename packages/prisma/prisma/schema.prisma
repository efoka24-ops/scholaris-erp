generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant (établissement) ─────────────────────────────────────────────

enum TenantType {
  PRIMAIRE
  SECONDAIRE
  SUPERIEUR
  TECHNIQUE
  FORMATION_PRO
}

enum TenantStatus {
  PUBLIC
  PRIVE
}

model Tenant {
  id         String       @id @default(uuid())
  code       String       @unique
  name       String
  type       TenantType
  status     TenantStatus @default(PUBLIC)
  address    String?
  phone      String?
  email      String?
  logoUrl    String?      @map("logo_url")
  // Configuration du moteur de calcul et autres paramètres (§1.4 du guide)
  configJson Json?        @map("config_json")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at")

  users         User[]
  roles         Role[]
  academicYears AcademicYear[]

  // Relations inverses Module 2 (structure pédagogique)
  cycles      Cycle[]
  departments Department[]
  programs    Program[]
  levels      Level[]
  rooms       Room[]
  classrooms  ClassRoom[]
  groups      Group[]

  @@map("tenants")
}

// ─── Utilisateurs & RBAC ────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id                  String     @id @default(uuid())
  tenantId            String     @map("tenant_id")
  email               String
  passwordHash        String     @map("password_hash")
  firstName           String     @map("first_name")
  lastName             String    @map("last_name")
  phone               String?
  status              UserStatus @default(ACTIVE)
  mfaEnabled          Boolean    @default(false) @map("mfa_enabled")
  mfaSecret           String?    @map("mfa_secret")
  lastLogin           DateTime?  @map("last_login")
  avatarUrl           String?    @map("avatar_url")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]
  auditLogs AuditLog[]

  // Relations inverses Module 2 (structure pédagogique) : un User peut être
  // référencé comme chef de département ou professeur principal d'une classe.
  departmentsHeaded Department[] @relation("DepartmentHeadTeacher")
  classroomsLed     ClassRoom[]  @relation("ClassRoomMainTeacher")

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id") // null = rôle système global (ex: SUPER_ADMIN)
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  resource    String
  action      String // create | read | update | delete | manage
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ─── Calendrier académique ───────────────────────────────────────────────

enum AcademicYearStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum PeriodType {
  SEQUENCE
  TRIMESTER
  SEMESTER
}

enum GradingStatus {
  CLOSED
  OPEN
  LOCKED
}

model AcademicYear {
  id        String             @id @default(uuid())
  tenantId  String             @map("tenant_id")
  label     String
  startDate DateTime           @map("start_date")
  endDate   DateTime           @map("end_date")
  status    AcademicYearStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  periods Period[]

  @@unique([tenantId, label])
  @@map("academic_years")
}

model Period {
  id             String        @id @default(uuid())
  academicYearId String        @map("academic_year_id")
  type           PeriodType
  number         Int
  startDate      DateTime      @map("start_date")
  endDate        DateTime      @map("end_date")
  gradingStatus  GradingStatus @default(CLOSED) @map("grading_status")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([academicYearId, type, number])
  @@map("periods")
}

// ─── Audit ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── Module 2 : Structure pédagogique ───────────────────────────────────────
// Hiérarchie : Cycle → (Program optionnel, ex: filière/série au 2nd cycle et
// supérieur) → Level → ClassRoom → Group. Program et Level portent chacun un
// cycleId direct (dénormalisé, cf. tableau du guide §2.2) pour permettre à un
// niveau sans filière (ex: collège) de s'attacher directement à son cycle.

enum Section {
  FRANCOPHONE
  ANGLOPHONE
}

enum GroupType {
  TD
  TP
  LV2
}

enum RoomType {
  SALLE_CLASSE
  LABORATOIRE
  SALLE_INFO
  AMPHITHEATRE
  TERRAIN_SPORT
}

model Cycle {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  order     Int
  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  levels   Level[]
  programs Program[]

  @@unique([tenantId, code])
  @@map("cycles")
}

model Department {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  code          String
  name          String
  headTeacherId String?  @map("head_teacher_id")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  headTeacher User?     @relation("DepartmentHeadTeacher", fields: [headTeacherId], references: [id])
  programs    Program[]

  @@unique([tenantId, code])
  @@map("departments")
}

model Program {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  code         String
  name         String
  cycleId      String   @map("cycle_id")
  departmentId String?  @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  cycle      Cycle       @relation(fields: [cycleId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  levels     Level[]

  @@unique([tenantId, code])
  @@map("programs")
}

model Level {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  order     Int
  cycleId   String   @map("cycle_id")
  programId String?  @map("program_id")
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  cycle      Cycle       @relation(fields: [cycleId], references: [id])
  program    Program?    @relation(fields: [programId], references: [id])
  classrooms ClassRoom[]

  @@unique([tenantId, code])
  @@map("levels")
}

model Room {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  type      RoomType @default(SALLE_CLASSE)
  capacity  Int?
  building  String?
  floor     String?
  equipment String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  classrooms ClassRoom[]

  @@unique([tenantId, code])
  @@map("rooms")
}

model ClassRoom {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  code          String
  name          String
  capacity      Int
  levelId       String   @map("level_id")
  mainTeacherId String?  @map("main_teacher_id")
  roomId        String?  @map("room_id")
  section       Section  @default(FRANCOPHONE)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  level       Level   @relation(fields: [levelId], references: [id])
  mainTeacher User?   @relation("ClassRoomMainTeacher", fields: [mainTeacherId], references: [id])
  room        Room?   @relation(fields: [roomId], references: [id])
  groups      Group[]

  @@unique([tenantId, code])
  @@map("classrooms")
}

model Group {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  code        String
  name        String
  type        GroupType
  classroomId String    @map("classroom_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  classroom ClassRoom @relation(fields: [classroomId], references: [id])

  @@unique([tenantId, classroomId, code])
  @@map("groups")
}
