generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant (établissement) ─────────────────────────────────────────────

enum TenantType {
  PRIMAIRE
  SECONDAIRE
  SUPERIEUR
  TECHNIQUE
  FORMATION_PRO
}

enum TenantStatus {
  PUBLIC
  PRIVE
}

model Tenant {
  id         String       @id @default(uuid())
  code       String       @unique
  name       String
  type       TenantType
  status     TenantStatus @default(PUBLIC)
  address    String?
  phone      String?
  email      String?
  logoUrl    String?      @map("logo_url")
  // Configuration du moteur de calcul et autres paramètres (§1.4 du guide)
  configJson Json?        @map("config_json")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at")

  users         User[]
  roles         Role[]
  academicYears AcademicYear[]

  // Relations inverses Module 2 (structure pédagogique)
  cycles      Cycle[]
  departments Department[]
  programs    Program[]
  levels      Level[]
  rooms       Room[]
  classrooms  ClassRoom[]
  groups      Group[]

  // Module 8 : Communication multicanal
  communicationTemplates CommunicationTemplate[]
  communicationMessages  CommunicationMessage[]
  userChannelPreferences UserChannelPreference[]
  internalMessages       InternalMessage[]

  // Module 3 : Matières, UE et EC
  subjects           Subject[]
  teachingUnits      TeachingUnit[]
  courseElements     CourseElement[]
  subjectAssignments SubjectAssignment[]

  // Module 4 : Inscriptions & Admissions
  students              Student[]
  parents               Parent[]
  enrollments           Enrollment[]
  admissionApplications AdmissionApplication[]
  matriculeSequences    MatriculeSequence[]

  // Module 7 : Gestion financière
  feeStructures    FeeStructure[]
  feeInstallments  FeeInstallment[]
  invoices         Invoice[]
  payments         Payment[]
  discounts        Discount[]
  receiptSequences ReceiptSequence[]

  // Module 5 : Notes & moteur de calcul
  grades            Grade[]
  gradeCalculations GradeCalculation[]
  periodResults     PeriodResult[]
  annualResults     AnnualResult[]

  @@map("tenants")
}

// ─── Utilisateurs & RBAC ────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id                  String     @id @default(uuid())
  tenantId            String     @map("tenant_id")
  email               String
  passwordHash        String     @map("password_hash")
  firstName           String     @map("first_name")
  lastName             String    @map("last_name")
  phone               String?
  status              UserStatus @default(ACTIVE)
  mfaEnabled          Boolean    @default(false) @map("mfa_enabled")
  mfaSecret           String?    @map("mfa_secret")
  lastLogin           DateTime?  @map("last_login")
  avatarUrl           String?    @map("avatar_url")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]
  auditLogs AuditLog[]

  // Relations inverses Module 2 (structure pédagogique) : un User peut être
  // référencé comme chef de département ou professeur principal d'une classe.
  departmentsHeaded Department[] @relation("DepartmentHeadTeacher")
  classroomsLed     ClassRoom[]  @relation("ClassRoomMainTeacher")

  // Module 8 : Communication multicanal
  receivedCommunications  CommunicationMessage[] @relation("CommunicationMessageRecipient")
  channelPreference       UserChannelPreference?  @relation("UserChannelPreferenceUser")
  sentInternalMessages    InternalMessage[]       @relation("InternalMessageSender")
  receivedInternalMessages InternalMessage[]      @relation("InternalMessageRecipient")

  // Module 3 : un User peut être référencé comme enseignant assigné à une matière/un EC.
  subjectAssignments SubjectAssignment[] @relation("SubjectAssignmentTeacher")

  // Module 7 : un User peut recevoir des paiements (secrétaire/comptable) ou approuver des réductions (admin).
  paymentsReceived    Payment[]  @relation("PaymentReceivedBy")
  discountsApproved   Discount[] @relation("DiscountApprovedBy")

  // Module 5 : un User peut être référencé comme enseignant saisissant une note.
  gradesEntered Grade[] @relation("GradeTeacher")

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id") // null = rôle système global (ex: SUPER_ADMIN)
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  resource    String
  action      String // create | read | update | delete | manage
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ─── Calendrier académique ───────────────────────────────────────────────

enum AcademicYearStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum PeriodType {
  SEQUENCE
  TRIMESTER
  SEMESTER
}

enum GradingStatus {
  CLOSED
  OPEN
  LOCKED
}

model AcademicYear {
  id        String             @id @default(uuid())
  tenantId  String             @map("tenant_id")
  label     String
  startDate DateTime           @map("start_date")
  endDate   DateTime           @map("end_date")
  status    AcademicYearStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  periods            Period[]
  subjectAssignments SubjectAssignment[]

  // Module 4 : Inscriptions & Admissions
  enrollments           Enrollment[]
  admissionApplications AdmissionApplication[]

  // Module 7 : Gestion financière
  feeStructures FeeStructure[]
  invoices      Invoice[]

  // Module 5 : Notes & moteur de calcul
  annualResults AnnualResult[]

  @@unique([tenantId, label])
  @@map("academic_years")
}

model Period {
  id             String        @id @default(uuid())
  academicYearId String        @map("academic_year_id")
  type           PeriodType
  number         Int
  startDate      DateTime      @map("start_date")
  endDate        DateTime      @map("end_date")
  gradingStatus  GradingStatus @default(CLOSED) @map("grading_status")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  // Module 5 : Notes & moteur de calcul
  grades            Grade[]
  gradeCalculations GradeCalculation[]
  periodResults     PeriodResult[]

  @@unique([academicYearId, type, number])
  @@map("periods")
}

// ─── Audit ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── Module 2 : Structure pédagogique ───────────────────────────────────────
// Hiérarchie : Cycle → (Program optionnel, ex: filière/série au 2nd cycle et
// supérieur) → Level → ClassRoom → Group. Program et Level portent chacun un
// cycleId direct (dénormalisé, cf. tableau du guide §2.2) pour permettre à un
// niveau sans filière (ex: collège) de s'attacher directement à son cycle.

enum Section {
  FRANCOPHONE
  ANGLOPHONE
}

enum GroupType {
  TD
  TP
  LV2
}

enum RoomType {
  SALLE_CLASSE
  LABORATOIRE
  SALLE_INFO
  AMPHITHEATRE
  TERRAIN_SPORT
}

model Cycle {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  order     Int
  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  levels   Level[]
  programs Program[]

  @@unique([tenantId, code])
  @@map("cycles")
}

model Department {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  code          String
  name          String
  headTeacherId String?  @map("head_teacher_id")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  headTeacher   User?          @relation("DepartmentHeadTeacher", fields: [headTeacherId], references: [id])
  programs      Program[]
  teachingUnits TeachingUnit[]

  @@unique([tenantId, code])
  @@map("departments")
}

model Program {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  code         String
  name         String
  cycleId      String   @map("cycle_id")
  departmentId String?  @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  cycle      Cycle       @relation(fields: [cycleId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  levels     Level[]

  @@unique([tenantId, code])
  @@map("programs")
}

model Level {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  order     Int
  cycleId   String   @map("cycle_id")
  programId String?  @map("program_id")
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  cycle      Cycle       @relation(fields: [cycleId], references: [id])
  program    Program?    @relation(fields: [programId], references: [id])
  classrooms ClassRoom[]

  // Module 7 : Gestion financière — une grille tarifaire peut cibler un niveau précis.
  feeStructures FeeStructure[]

  @@unique([tenantId, code])
  @@map("levels")
}

model Room {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  name      String
  type      RoomType @default(SALLE_CLASSE)
  capacity  Int?
  building  String?
  floor     String?
  equipment String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  classrooms ClassRoom[]

  @@unique([tenantId, code])
  @@map("rooms")
}

model ClassRoom {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  code          String
  name          String
  capacity      Int
  levelId       String   @map("level_id")
  mainTeacherId String?  @map("main_teacher_id")
  roomId        String?  @map("room_id")
  section       Section  @default(FRANCOPHONE)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  level              Level               @relation(fields: [levelId], references: [id])
  mainTeacher        User?               @relation("ClassRoomMainTeacher", fields: [mainTeacherId], references: [id])
  room               Room?               @relation(fields: [roomId], references: [id])
  groups             Group[]
  subjectAssignments SubjectAssignment[]

  // Module 4 : Inscriptions & Admissions
  enrollments Enrollment[]

  // Module 5 : Notes & moteur de calcul
  gradeCalculations GradeCalculation[]
  periodResults     PeriodResult[]
  annualResults     AnnualResult[]

  @@unique([tenantId, code])
  @@map("classrooms")
}

model Group {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  code        String
  name        String
  type        GroupType
  classroomId String    @map("classroom_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  classroom ClassRoom @relation(fields: [classroomId], references: [id])

  @@unique([tenantId, classroomId, code])
  @@map("groups")
}

// ─── Module 8 : Communication multicanal (§23 du guide) ─────────────────────
// Modèles additifs uniquement, ajoutés en fin de fichier pour limiter les
// conflits de merge avec les modules 2-7 développés en parallèle sur ce
// même schéma. Aucune modification du modèle User existant : les préférences
// de canal vivent dans un modèle séparé (UserChannelPreference) en relation 1:1.

enum Channel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  INTERNAL
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

model CommunicationTemplate {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  code       String
  name       String
  channel    Channel
  subjectFr  String?  @map("subject_fr")
  subjectEn  String?  @map("subject_en")
  bodyFr     String   @map("body_fr")
  bodyEn     String?  @map("body_en")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant                  @relation(fields: [tenantId], references: [id])
  messages CommunicationMessage[]

  @@unique([tenantId, code])
  @@map("communication_templates")
}

model CommunicationMessage {
  id                 String        @id @default(uuid())
  tenantId           String        @map("tenant_id")
  templateId         String?       @map("template_id") // null = message ad-hoc (pas de template)
  channel            Channel
  recipientUserId    String        @map("recipient_user_id")
  subject            String?
  body               String
  status             MessageStatus @default(PENDING)
  providerMessageId  String?       @map("provider_message_id")
  errorMessage       String?       @map("error_message")
  sentAt             DateTime?     @map("sent_at")
  createdAt          DateTime      @default(now()) @map("created_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  template      CommunicationTemplate?  @relation(fields: [templateId], references: [id])
  recipientUser User                    @relation("CommunicationMessageRecipient", fields: [recipientUserId], references: [id])

  @@map("communication_messages")
}

model UserChannelPreference {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  userId           String   @unique @map("user_id")
  preferredChannel Channel  @map("preferred_channel")
  fallbackChannel  Channel? @map("fallback_channel")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation("UserChannelPreferenceUser", fields: [userId], references: [id])

  @@map("user_channel_preferences")
}

// ─── Module 4 : Inscriptions & Admissions (§4 du guide) ─────────────────────
// Modèles additifs en fin de fichier (même stratégie que le Module 8) pour
// limiter les conflits de merge. Toutes les entités portent tenant_id,
// created_at / updated_at / deleted_at (soft delete, jamais de suppression
// physique — §0.3 du guide).

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  GRADUATED
  EXCLUDED
  ABANDONED
}

enum ParentRelationship {
  FATHER
  MOTHER
  GUARDIAN
}

enum EnrollmentType {
  NEW
  RE_ENROLLMENT
  TRANSFER
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  CANCELLED
}

enum EnrollmentRegime {
  EXTERNAL
  HALF_BOARD
  BOARDING
}

enum AdmissionType {
  EXAM
  DOSSIER
  DIRECT
}

enum AdmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
  WAITLISTED
}

model Student {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  matricule        String
  firstName        String        @map("first_name")
  lastName         String        @map("last_name")
  dateOfBirth      DateTime      @map("date_of_birth")
  placeOfBirth     String?       @map("place_of_birth")
  gender           Gender
  nationality      String        @default("Camerounaise")
  photoUrl         String?       @map("photo_url")
  bloodGroup       String?       @map("blood_group")
  allergies        String?
  handicap         String?
  emergencyContact String?       @map("emergency_contact")
  status           StudentStatus @default(ACTIVE)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  parents     StudentParent[]
  enrollments Enrollment[]

  // Module 7 : Gestion financière
  invoices  Invoice[]
  payments  Payment[]
  discounts Discount[]

  // Module 5 : Notes & moteur de calcul
  grades            Grade[]
  gradeCalculations GradeCalculation[]
  periodResults     PeriodResult[]
  annualResults     AnnualResult[]

  @@unique([tenantId, matricule])
  @@index([tenantId, lastName, firstName])
  @@map("students")
}

model Parent {
  id           String             @id @default(uuid())
  tenantId     String             @map("tenant_id")
  firstName    String             @map("first_name")
  lastName     String             @map("last_name")
  phone        String
  whatsapp     String?
  email        String?
  profession   String?
  address      String?
  relationship ParentRelationship
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  deletedAt    DateTime?          @map("deleted_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  students StudentParent[]

  @@map("parents")
}

// Table de liaison M:N élève ↔ parent : la relation (père/mère/tuteur) est
// portée par le lien, un même Parent pouvant être père d'un élève et tuteur
// d'un autre.
model StudentParent {
  studentId    String             @map("student_id")
  parentId     String             @map("parent_id")
  relationship ParentRelationship

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
  @@map("student_parents")
}

model Enrollment {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  studentId       String           @map("student_id")
  classroomId     String           @map("classroom_id")
  academicYearId  String           @map("academic_year_id")
  enrollmentDate  DateTime         @default(now()) @map("enrollment_date")
  type            EnrollmentType   @default(NEW)
  status          EnrollmentStatus @default(ACTIVE)
  regime          EnrollmentRegime @default(EXTERNAL)
  isRepeater      Boolean          @default(false) @map("is_repeater")
  previousSchool  String?          @map("previous_school")
  previousAverage Float?           @map("previous_average")
  documents       Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  classroom    ClassRoom    @relation(fields: [classroomId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  // Module 7 : Gestion financière — une facture est rattachée à une inscription précise.
  invoices Invoice[]

  @@index([tenantId, classroomId, status])
  @@index([tenantId, studentId, academicYearId])
  @@map("enrollments")
}

model AdmissionApplication {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  applicantName  String          @map("applicant_name")
  applicantInfo  Json?           @map("applicant_info")
  type           AdmissionType   @default(DOSSIER)
  score          Float?
  rank           Int?
  status         AdmissionStatus @default(PENDING)
  academicYearId String          @map("academic_year_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@index([tenantId, status])
  @@map("admission_applications")
}

// Compteur atomique de matricules par tenant + année : incrémenté via un
// upsert `lastNumber: { increment: 1 }` dans la même transaction que la
// création de l'élève (pas de trou ni de doublon possible).
model MatriculeSequence {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  year       String
  lastNumber Int      @default(0) @map("last_number")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year])
  @@map("matricule_sequences")
}

model InternalMessage {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  senderUserId   String    @map("sender_user_id")
  recipientUserId String   @map("recipient_user_id")
  body           String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant       Tenant @relation(fields: [tenantId], references: [id])
  senderUser   User   @relation("InternalMessageSender", fields: [senderUserId], references: [id])
  recipientUser User  @relation("InternalMessageRecipient", fields: [recipientUserId], references: [id])

  @@map("internal_messages")
}

// ─── Module 3 : Matières, UE et EC (référentiel des disciplines) ─────────────
// Matières simples (coefficient + heures hebdo) pour le primaire/secondaire ;
// UE (TeachingUnit) → EC (CourseElement) pour le supérieur LMD (crédits,
// volumes CM/TD/TP). SubjectAssignment relie un enseignant à une matière OU
// à un EC pour une classe et une année académique données. Modèles additifs
// en fin de fichier (même convention que le Module 8) ; les relations inverses
// nécessaires ont été ajoutées sur Tenant/User/Department/ClassRoom/AcademicYear.

enum SubjectCategory {
  LITERARY
  SCIENTIFIC
  TECHNICAL
  LANGUAGE
  SPORTS
}

model Subject {
  id                   String          @id @default(uuid())
  tenantId             String          @map("tenant_id")
  code                 String
  name                 String
  coefficient          Decimal         @db.Decimal(5, 2)
  weeklyHours          Int             @map("weekly_hours")
  category             SubjectCategory
  isEliminatory        Boolean         @default(false) @map("is_eliminatory")
  // Seuil (note) en dessous duquel la matière est éliminatoire ; 0 = désactivé.
  eliminatoryThreshold Decimal         @default(0) @map("eliminatory_threshold") @db.Decimal(5, 2)
  // Niveaux (Level) auxquels la matière est enseignée. Tableau d'identifiants
  // plutôt qu'une table de jointure : pas de contrainte référentielle forte
  // requise ici, et le filtre `has` suffit aux besoins de consultation.
  levelIds             String[]        @default([]) @map("level_ids")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  deletedAt            DateTime?       @map("deleted_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  assignments SubjectAssignment[]

  // Module 5 : Notes & moteur de calcul
  grades            Grade[]
  gradeCalculations GradeCalculation[]

  @@unique([tenantId, code])
  @@map("subjects")
}

model TeachingUnit {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  code          String
  name          String
  credits       Int
  semester      Int
  isFundamental Boolean   @default(false) @map("is_fundamental")
  departmentId  String    @map("department_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  department     Department      @relation(fields: [departmentId], references: [id])
  courseElements CourseElement[]

  @@unique([tenantId, code])
  @@map("teaching_units")
}

model CourseElement {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  code           String
  name           String
  credits        Int
  hoursCm        Int       @default(0) @map("hours_cm")
  hoursTd        Int       @default(0) @map("hours_td")
  hoursTp        Int       @default(0) @map("hours_tp")
  coefficient    Decimal   @default(1) @db.Decimal(5, 2)
  teachingUnitId String    @map("teaching_unit_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  teachingUnit TeachingUnit        @relation(fields: [teachingUnitId], references: [id])
  assignments  SubjectAssignment[]

  // Module 5 : Notes & moteur de calcul
  grades            Grade[]
  gradeCalculations GradeCalculation[]

  @@unique([tenantId, code])
  @@map("course_elements")
}

model SubjectAssignment {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  // Exactement l'un des deux est renseigné : subjectId (secondaire) OU
  // courseElementId (supérieur LMD). Validé côté service.
  subjectId       String?   @map("subject_id")
  courseElementId String?   @map("course_element_id")
  teacherId       String    @map("teacher_id")
  classroomId     String    @map("classroom_id")
  academicYearId  String    @map("academic_year_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  courseElement CourseElement? @relation(fields: [courseElementId], references: [id])
  teacher       User           @relation("SubjectAssignmentTeacher", fields: [teacherId], references: [id])
  classroom     ClassRoom      @relation(fields: [classroomId], references: [id])
  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id])

  // NB : Postgres n'applique pas l'unicité quand subjectId/courseElementId est
  // NULL — le contrôle applicatif (409) dans SubjectAssignmentsService reste la
  // barrière principale ; ces index couvrent les courses concurrentes usuelles.
  @@unique([tenantId, subjectId, classroomId, academicYearId])
  @@unique([tenantId, courseElementId, classroomId, academicYearId])
  @@map("subject_assignments")
}

// ─── Module 7 : Gestion financière (frais de scolarité, paiements) ──────────
// Modèles additifs en fin de fichier (même convention que les modules 3/4/8) ;
// les relations inverses nécessaires ont été ajoutées sur Tenant/User/Level/
// AcademicYear/Student/Enrollment. FeeStructure définit une grille tarifaire
// par niveau (levelId = null → s'applique à tous les niveaux de l'année) et
// par année académique ; ses FeeInstallment sont les tranches affichées à
// titre indicatif (échéancier) mais le paiement se fait toujours contre le
// solde global de la facture, jamais tranche par tranche. Invoice est générée
// depuis la grille applicable au niveau de la classe d'un Enrollment donné.
// Montants stockés en Float (comme Enrollment.previousAverage) : aucune
// convention Decimal préexistante dans le schéma pour les valeurs monétaires.

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CHECK
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model FeeStructure {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  name           String
  levelId        String?   @map("level_id")
  academicYearId String    @map("academic_year_id")
  totalAmount    Float     @map("total_amount")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  level        Level?           @relation(fields: [levelId], references: [id])
  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id])
  installments FeeInstallment[]
  invoices     Invoice[]

  @@index([tenantId, academicYearId, levelId])
  @@map("fee_structures")
}

model FeeInstallment {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  feeStructureId String    @map("fee_structure_id")
  label          String
  amount         Float
  dueDate        DateTime  @map("due_date")
  order          Int
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])

  @@index([tenantId, feeStructureId])
  @@map("fee_installments")
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  studentId      String        @map("student_id")
  enrollmentId   String        @map("enrollment_id")
  feeStructureId String        @map("fee_structure_id")
  academicYearId String        @map("academic_year_id")
  totalAmount    Float         @map("total_amount")
  paidAmount     Float         @default(0) @map("paid_amount")
  balance        Float
  // Échéance retenue pour le calcul du statut OVERDUE : la plus tardive des
  // tranches de la grille au moment de la génération (null si la grille n'a
  // aucune tranche définie).
  dueDate        DateTime?     @map("due_date")
  status         InvoiceStatus @default(PENDING)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  payments     Payment[]
  discounts    Discount[]

  @@index([tenantId, studentId, status])
  @@index([tenantId, enrollmentId])
  @@map("invoices")
}

model Payment {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  invoiceId     String        @map("invoice_id")
  studentId     String        @map("student_id")
  amount        Float
  method        PaymentMethod
  reference     String?
  receiptNumber String        @map("receipt_number")
  paidAt        DateTime      @default(now()) @map("paid_at")
  receivedBy    String?       @map("received_by")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  tenant         Tenant  @relation(fields: [tenantId], references: [id])
  invoice        Invoice @relation(fields: [invoiceId], references: [id])
  student        Student @relation(fields: [studentId], references: [id])
  receivedByUser User?   @relation("PaymentReceivedBy", fields: [receivedBy], references: [id])

  @@unique([tenantId, receiptNumber])
  @@index([tenantId, invoiceId])
  @@index([tenantId, studentId])
  @@map("payments")
}

model Discount {
  id         String       @id @default(uuid())
  tenantId   String       @map("tenant_id")
  // Au moins l'un des deux est renseigné (validé côté service) : invoiceId
  // applique immédiatement la réduction à cette facture ; studentId seul
  // enregistre une bourse générale sans impact immédiat sur une facture.
  studentId  String?      @map("student_id")
  invoiceId  String?      @map("invoice_id")
  type       DiscountType
  value      Float
  reason     String?
  approvedBy String       @map("approved_by")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at")

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  student        Student? @relation(fields: [studentId], references: [id])
  invoice        Invoice? @relation(fields: [invoiceId], references: [id])
  approvedByUser User     @relation("DiscountApprovedBy", fields: [approvedBy], references: [id])

  @@index([tenantId, studentId])
  @@index([tenantId, invoiceId])
  @@map("discounts")
}

// Compteur atomique de numéros de reçu par tenant + année (même pattern que
// MatriculeSequence du Module 4) : incrémenté via upsert `lastNumber: { increment: 1 }`
// dans la même transaction que la création du Payment — deux paiements
// concurrents ne peuvent jamais obtenir le même numéro.
model ReceiptSequence {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  year       String
  lastNumber Int      @default(0) @map("last_number")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year])
  @@map("receipt_sequences")
}

// ─── Module 5 : Saisie des notes et moteur de calcul (§5 du guide) ──────────
// Grade (note unitaire) → GradeCalculation (moyenne matière/EC calculée pour
// une période) → PeriodResult (moyenne générale + classement + délibération
// d'un élève sur une période) → AnnualResult (bilan annuel : moyenne, rang,
// mention, décision de passage, GPA pour le LMD). Le moteur de calcul lui-même
// (CalculationEngineService) est un service sans état, indépendant de Prisma :
// il consomme la configuration existante `Tenant.configJson` (voir
// calculationEngineSchema, packages/shared/src/schemas/settings.schema.ts) sans
// la redéfinir. Modèles additifs en fin de fichier (même convention que les
// modules 3/4/8) ; toutes les entités portent tenant_id, created_at/updated_at/
// deleted_at (soft delete, jamais de suppression physique — §0.3 du guide).

enum GradeType {
  TEST
  HOMEWORK
  EXAM
  RESIT
}

enum AnnualDecision {
  PASS
  REPEAT
  EXCLUDE
}

model Grade {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  studentId       String    @map("student_id")
  // Exactement l'un des deux est renseigné : subjectId (primaire/secondaire) OU
  // courseElementId (supérieur LMD). Validé côté service (même convention que
  // SubjectAssignment).
  subjectId       String?   @map("subject_id")
  courseElementId String?   @map("course_element_id")
  periodId        String    @map("period_id")
  teacherId       String    @map("teacher_id")
  type            GradeType @default(TEST)
  // Note brute sur maxValue ; null si isAbsent=true et qu'aucune note de
  // substitution n'a été saisie (cf. CalculationEngineService.handleAbsence).
  value           Decimal?  @db.Decimal(5, 2)
  maxValue        Decimal   @default(20) @map("max_value") @db.Decimal(5, 2)
  // Pondération de cette évaluation dans la moyenne (matière/EC) de la période.
  weight          Decimal   @default(1) @db.Decimal(5, 2)
  date            DateTime  @default(now())
  comment         String?
  isAbsent        Boolean   @default(false) @map("is_absent")
  isJustified     Boolean   @default(false) @map("is_justified")
  // Verrouillée par l'enseignant (PUT /grades/lock/...) : non modifiable sauf
  // déverrouillage explicite (censeur/admin, grades:unlock).
  isLocked        Boolean   @default(false) @map("is_locked")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  student       Student        @relation(fields: [studentId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  courseElement CourseElement? @relation(fields: [courseElementId], references: [id])
  period        Period         @relation(fields: [periodId], references: [id])
  teacher       User           @relation("GradeTeacher", fields: [teacherId], references: [id])

  @@index([tenantId, studentId, periodId])
  @@index([tenantId, subjectId, periodId])
  @@index([tenantId, courseElementId, periodId])
  @@index([tenantId, periodId, isLocked])
  @@map("grades")
}

// Moyenne calculée (matière ou EC) d'un élève sur une période, issue du moteur
// de calcul (POST /grades/calculate/:classId/:periodId). classroomId est
// dénormalisé depuis l'inscription active de l'élève au moment du calcul, pour
// permettre un classement rapide par classe sans re-parcourir les inscriptions.
model GradeCalculation {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  studentId         String    @map("student_id")
  periodId          String    @map("period_id")
  subjectId         String?   @map("subject_id")
  courseElementId   String?   @map("course_element_id")
  classroomId       String    @map("classroom_id")
  calculatedAverage Decimal   @map("calculated_average") @db.Decimal(5, 2)
  coefficient       Decimal   @default(1) @map("coefficient") @db.Decimal(5, 2)
  weightedTotal     Decimal   @map("weighted_total") @db.Decimal(8, 2)
  // Rang de l'élève dans la matière/EC au sein de la classe (ex æquo => même rang).
  rank              Int?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  student       Student        @relation(fields: [studentId], references: [id])
  period        Period         @relation(fields: [periodId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  courseElement CourseElement? @relation(fields: [courseElementId], references: [id])
  classroom     ClassRoom      @relation(fields: [classroomId], references: [id])

  // NB : comme pour SubjectAssignment, Postgres n'applique pas l'unicité quand
  // subjectId/courseElementId est NULL — le service recalcule (upsert manuel)
  // plutôt que de s'appuyer uniquement sur la contrainte.
  @@unique([tenantId, studentId, periodId, subjectId, courseElementId])
  @@index([tenantId, classroomId, periodId])
  @@map("grade_calculations")
}

// Bilan d'un élève sur une période (moyenne générale, rang, mention,
// délibération). isPublished contrôle la visibilité pour parents/élèves.
model PeriodResult {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  studentId      String    @map("student_id")
  periodId       String    @map("period_id")
  classroomId    String    @map("classroom_id")
  generalAverage Decimal   @map("general_average") @db.Decimal(5, 2)
  rank           Int?
  totalStudents  Int?      @map("total_students")
  mention        String?
  // Décision de la délibération (texte libre : "Admis(e)", "Avertissement"...).
  decision       String?
  observations   String?
  teacherComment String?   @map("teacher_comment")
  isPublished    Boolean   @default(false) @map("is_published")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])
  period    Period    @relation(fields: [periodId], references: [id])
  classroom ClassRoom @relation(fields: [classroomId], references: [id])

  @@unique([tenantId, studentId, periodId])
  @@index([tenantId, classroomId, periodId])
  @@map("period_results")
}

// Bilan annuel d'un élève (POST /grades/calculate-annual/:classId).
model AnnualResult {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  studentId        String          @map("student_id")
  classroomId      String          @map("classroom_id")
  academicYearId   String          @map("academic_year_id")
  annualAverage    Decimal         @map("annual_average") @db.Decimal(5, 2)
  rank             Int?
  mention          String?
  decision         AnnualDecision?
  // LMD uniquement : nombre de crédits validés / GPA (échelle configurable via
  // calculationEngineSchema.gpaScale).
  creditsValidated Int?            @map("credits_validated")
  gpa              Decimal?        @db.Decimal(4, 2)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  classroom    ClassRoom    @relation(fields: [classroomId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([tenantId, studentId, academicYearId])
  @@index([tenantId, classroomId, academicYearId])
  @@map("annual_results")
}
