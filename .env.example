# --- Base de données & cache (docker-compose.yml) ---
DATABASE_URL="postgresql://scholaris:scholaris_dev_password@localhost:5432/scholaris?schema=public"
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# --- API ---
API_PORT=3001
API_GLOBAL_PREFIX="api"
CORS_ORIGIN="http://localhost:3000"

# --- Seed (super admin initial) ---
SEED_SUPER_ADMIN_EMAIL="admin@scholaris.dev"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!"
SEED_TENANT_CODE="DEMO"
SEED_TENANT_NAME="Établissement Démo"

# --- Module 8 : Communication multicanal (§23 du guide) ---
# Brevo (email transactionnel) — https://api.brevo.com/v3/smtp/email
BREVO_API_KEY="change-me-brevo-api-key"
BREVO_SENDER_EMAIL="no-reply@scholaris.dev"
# Africa's Talking (SMS) — https://api.africastalking.com/version1/messaging
AFRICASTALKING_API_KEY="change-me-africastalking-api-key"
AFRICASTALKING_USERNAME="sandbox"
# Meta WhatsApp Cloud API — https://graph.facebook.com/v20.0/{phone-number-id}/messages
WHATSAPP_CLOUD_API_TOKEN="change-me-whatsapp-cloud-api-token"
WHATSAPP_PHONE_NUMBER_ID="change-me-whatsapp-phone-number-id"
# Jeton de vérification du webhook (handshake GET hub.mode/hub.verify_token/hub.challenge)
WHATSAPP_WEBHOOK_VERIFY_TOKEN="change-me-webhook-verify-token"
