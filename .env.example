# --- Base de données & cache (docker-compose.yml) ---
DATABASE_URL="postgresql://scholaris:scholaris_dev_password@localhost:5432/scholaris?schema=public"
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# --- API ---
API_PORT=3001
API_GLOBAL_PREFIX="api"
CORS_ORIGIN="http://localhost:3000"

# --- Seed (super admin initial) ---
SEED_SUPER_ADMIN_EMAIL="admin@scholaris.dev"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!"
SEED_TENANT_CODE="DEMO"
SEED_TENANT_NAME="Établissement Démo"
