{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "@scholaris/prisma#build": {
      "outputs": ["dist/**", "generated/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["NEST_API_URL", "NEXT_PUBLIC_TENANT_CODE", "DATABASE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"]
    }
  }
}
