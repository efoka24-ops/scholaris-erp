# ═══════════════════════════════════════════════════════════════════════════
# SCHOLARIS ERP — Variables d'environnement de PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
# Copier vers .env.production et renseigner les vraies valeurs. Ne jamais committer
# ce fichier une fois rempli. Liste exhaustive basée sur .env.example (dev) +
# usages réels de process.env dans apps/api/src (voir main.ts, app.module.ts).
#
# Sur Railway (déploiement actuel de production), ces variables sont définies dans
# Settings > Variables du service, PAS via ce fichier — .env.production sert au
# déploiement auto-hébergé (docker-compose.production.yml).

# --- Base de données ---
# Auto-hébergé : pointe vers le service "postgres" du docker-compose.production.yml
POSTGRES_DB="scholaris"
POSTGRES_USER="scholaris"
POSTGRES_PASSWORD="CHANGEME_mot_de_passe_fort"
DATABASE_URL="postgresql://scholaris:CHANGEME_mot_de_passe_fort@postgres:5432/scholaris?schema=public"

# --- Cache / files (BullMQ éventuel, rate limiting) ---
REDIS_URL="redis://redis:6379"

# --- JWT (obligatoires en production, pas de valeur par défaut acceptable) ---
JWT_ACCESS_SECRET="CHANGEME_genere_avec_openssl_rand_-hex_32"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGEME_genere_avec_openssl_rand_-hex_32"
JWT_REFRESH_EXPIRES_IN="7d"

# --- API ---
NODE_ENV="production"
PORT=3001
API_PORT=3001
API_GLOBAL_PREFIX="api"
# Domaine du frontend de production (pas de wildcard en prod)
CORS_ORIGIN="https://votre-domaine.tld"

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_URL="https://votre-domaine.tld/api"

# --- Seed (super admin initial — à changer immédiatement après le premier déploiement) ---
SEED_SUPER_ADMIN_EMAIL="admin@votre-etablissement.tld"
SEED_SUPER_ADMIN_PASSWORD="CHANGEME_mot_de_passe_fort"
SEED_TENANT_CODE="PROD"
SEED_TENANT_NAME="Nom de l'établissement"

# --- Module 8 : Communication multicanal ---
# Email transactionnel : SMTP (prioritaire si SMTP_HOST est defini) ou Brevo (repli).
# SMTP classique (ex: boite mail de l'etablissement) :
SMTP_HOST="CHANGEME (ex: mx-dc03.ewodi.net)"
SMTP_PORT="587"
SMTP_USER="CHANGEME (ex: noreply@votre-domaine.tld)"
SMTP_PASSWORD="CHANGEME — ne JAMAIS committer la vraie valeur, definir uniquement dans le dashboard Railway/Vercel"
SMTP_FROM_NAME="SCHOLARIS"
SMTP_FROM_EMAIL="CHANGEME (par defaut = SMTP_USER)"
# Brevo (email transactionnel, utilise seulement si SMTP_HOST est absent) — https://api.brevo.com/v3/smtp/email
BREVO_API_KEY="CHANGEME"
BREVO_SENDER_EMAIL="no-reply@votre-domaine.tld"
# Africa's Talking (SMS) — https://api.africastalking.com/version1/messaging
AFRICASTALKING_API_KEY="CHANGEME"
AFRICASTALKING_USERNAME="CHANGEME"
# Meta WhatsApp Cloud API — https://graph.facebook.com/v20.0/{phone-number-id}/messages
WHATSAPP_CLOUD_API_TOKEN="CHANGEME"
WHATSAPP_PHONE_NUMBER_ID="CHANGEME"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="CHANGEME"

# --- MinIO / stockage S3-compatible (logos, documents élèves, PDF bulletins/reçus) ---
# Utilisé par docker-compose.production.yml (auto-hébergé). Sur Railway, remplacer par
# un bucket S3 managé (AWS S3, Backblaze B2, etc.) et adapter les variables ci-dessous
# dans le module de stockage de fichiers correspondant.
MINIO_ROOT_USER="scholaris_minio_admin"
MINIO_ROOT_PASSWORD="CHANGEME_mot_de_passe_fort"
MINIO_ENDPOINT="http://minio:9000"
MINIO_BUCKET="scholaris-files"

# --- Backups (scripts/backup-db.sh) ---
BACKUP_S3_BUCKET="scholaris-backups"
BACKUP_S3_ENDPOINT="http://minio:9000"
BACKUP_RETENTION_DAYS=30
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY si utilisation du CLI `aws` plutôt que `mc`
